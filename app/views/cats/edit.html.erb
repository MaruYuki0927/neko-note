<h1>猫プロフィール編集</h1>

<%= form_with model: @cat do |f| %>

  <div>
    <%= f.label :name, "名前" %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :age, "年齢" %>
    <%= f.number_field :age %>
  </div>

  <div>
    <%= f.label :introduction, "自己紹介" %>
    <%= f.text_area :introduction %>
  </div>

  <div>
    <%= f.submit "更新する" %>
  </div>

<% end %>
<h1 class="mt-4 mb-4 text-white">猫一覧</h1>

<div class="container">

  <div class="row">

    <% @cats.each do |cat| %>

      <div class="col-md-6 col-lg-4">

        <div class="card mb-4 shadow-sm">

          <% if cat.image.attached? %>

            <%= image_tag cat.image,
                class: "rounded-circle cat-icon mx-auto mt-3" %>

          <% end %>

          <div class="card-body">

            <h3 class="card-title">

              <%= link_to cat.name,
                  cat_path(cat),
                  class: "text-dark text-decoration-none" %>

            </h3>

                <p class="text-muted mb-1">

                  年齢：<%= cat.age %>歳
            
                </p>
            
                <p class="text-muted">
            
                  性別：<%= cat.gender %>
            
                </p>

            <p class="card-text">

              飼い主：
              <%= link_to cat.user.name,
                  user_path(cat.user),
                  class: "text-dark text-decoration-none" %>

            </p>

          </div>

        </div>

      </div>

    <% end %>

  </div>

</div>
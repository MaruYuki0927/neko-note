<h1><%= @user.name %>のマイページ</h1>

<p>
  <%= link_to "フォロー #{@user.followings.count}",
      followings_user_path(@user) %>
</p>

<p>
  <%= link_to "フォロワー #{@user.followers.count}",
      followers_user_path(@user) %>
</p>

<% if user_signed_in? %>

  <% unless @user == current_user %>

    <% if current_user.followings.include?(@user) %>

      <%= button_to "フォロー解除",
        user_relationships_path(@user),
        method: :delete %>

    <% else %>

      <%= button_to "フォロー",
        user_relationships_path(@user) %>

    <% end %>

  <% end %>

<% end %>

<h2>投稿一覧</h2>

<% @posts.each do |post| %>
  <div>
    <h3><%= link_to post.title, post_path(post) %></h3>
    <p><%= post.body %></p>
  </div>
<% end %>
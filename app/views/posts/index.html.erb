<h1 class="mt-4 mb-4">投稿一覧</h1>

<div class="container">

  <div class="row">

    <% @posts.each do |post| %>

      <div class="col-md-6 col-lg-4">

        <div class="card mb-4 shadow-sm">

          <% if post.image.attached? %>
            <%= image_tag post.image,
                class: "card-img-top post-image" %>
          <% end %>

          <div class="card-body">

            <h3 class="card-title">
              <%= link_to post.title,
                  post_path(post),
                  class: "text-dark text-decoration-none" %>
            </h3>

            <p class="card-text">
              <%= post.body %>
            </p>

            <p>
              投稿者：
              <%= link_to post.user.name,
                  user_path(post.user),
                  class: "text-dark" %>
            </p>

            <p>
              猫：
              <%= link_to post.cat.name,
                  cat_path(post.cat),
                  class: "text-dark" %>
            </p>

            <% if post.user == current_user %>

              <%= link_to "編集",
                  edit_post_path(post),
                  class: "btn btn-dark btn-sm" %>

              <%= link_to "削除",
                  post_path(post),
                  data: { turbo_method: :delete },
                  class: "btn btn-outline-dark btn-sm" %>

            <% end %>

          </div>

        </div>

      </div>

    <% end %>

  </div>

</div>

<div class="d-flex justify-content-center mt-4">
  <%= paginate @posts %>
</div>
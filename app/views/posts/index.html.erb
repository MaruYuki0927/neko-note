<h1>投稿一覧</h1>

<% @posts.each do |post| %>
  <div>
    <h3>
      <%= link_to post.title, post_path(post) %>
    </h3>

    <p><%= post.body %></p>
  </div>

  <% if post.image.attached? %>
    <%= image_tag post.image %>
  <% end %>

  投稿者：<%= post.user.name %>

  <% if post.user == current_user %>
    <%= link_to "編集", edit_post_path(post) %>
    <%= link_to "削除", post_path(post), data: { turbo_method: :delete } %>
  <% end %>

<% end %>
<div class="container mt-4">

  <div class="row justify-content-center">

    <div class="col-md-8">

      <div class="card shadow-sm">

        <% if @post.image.attached? %>
          <%= image_tag @post.image,
              class: "card-img-top post-image" %>
        <% end %>

        <div class="card-body">

          <h1 class="card-title mb-3 text-dark">
            <%= @post.title %>
          </h1>

          <p class="card-text text-dark">
            <%= @post.body %>
          </p>

          <hr>

          <p class="text-dark">
            投稿者：
            <%= link_to @post.user.name,
                user_path(@post.user),
                class: "text-dark text-decoration-none" %>
          </p>

          <p class="text-dark">
            猫：
            <%= link_to @post.cat.name,
                cat_path(@post.cat),
                class: "text-dark text-decoration-none" %>
          </p>

          <% if @post.user == current_user %>

            <%= link_to "編集",
                edit_post_path(@post),
                class: "btn btn-dark btn-sm" %>

            <%= link_to "削除",
                post_path(@post),
                data: {
                  turbo_method: :delete,
                  turbo_confirm: "本当に削除しますか？"
                },
                class: "btn btn-outline-dark btn-sm" %>

          <% end %>

          <hr>

          <% if user_signed_in? %>

            <% if current_user.likes.find_by(post_id: @post.id) %>

              <%= link_to "いいね解除",
                  post_like_path(@post,
                  current_user.likes.find_by(post_id: @post.id)),
                  data: { turbo_method: :delete },
                  class: "btn btn-outline-dark btn-sm" %>

            <% else %>

              <%= link_to "いいね",
                  post_likes_path(@post),
                  data: { turbo_method: :post },
                  class: "btn btn-dark btn-sm" %>

            <% end %>

          <% end %>

          <p class="mt-3 text-dark">

           ❤️ <%= @post.likes.count %>
           
            <span class="ms-3">
             💬 <%= @post.comments.count %>
            </span>

          </p>

        </div>

      </div>

    </div>

  </div>

</div>


<div class="container mt-4">

  <div class="row justify-content-center">

    <div class="col-md-8">

      <h3 class="mb-3 text-white">コメントする</h3>

      <div class="card shadow-sm mb-4">

        <div class="card-body">

          <%= form_with(model: [@post, Comment.new]) do |f| %>

            <div class="mb-3">

              <%= f.text_area :body,
                  class: "form-control",
                  rows: 3,
                  placeholder: "コメントを書く..." %>

            </div>

            <%= f.submit "コメントする",
                class: "btn btn-dark" %>

          <% end %>

        </div>

      </div>

      <h3 class="mb-3 text-white">コメント一覧</h3>

      <% @post.comments.each do |comment| %>

        <div class="card shadow-sm mb-3">

          <div class="card-body">

            <p class="mb-2">

              <strong>
                <%= comment.user.name %>
              </strong>

            </p>

            <p class="text-dark">
              <%= comment.body %>
            </p>

            <% if comment.user == current_user %>

              <%= link_to "削除",
                  post_comment_path(@post, comment),
                  data: {
                    turbo_method: :delete,
                    turbo_confirm: "削除する？"
                  },
                  class: "btn btn-outline-dark btn-sm" %>

            <% end %>

          </div>

        </div>

      <% end %>

    </div>

  </div>

</div>
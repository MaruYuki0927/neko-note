<h1>新規投稿</h1>

<%= form_with model: @post, local: true do |f| %>

  <div>
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :body, "本文" %><br>
    <%= f.text_area :body %>
  </div>

  <div>
    <%= f.label :image, "画像" %><br>
    <%= f.file_field :image %>
  </div>

  <div>
    <%= f.label :cat_id, "猫を選ぶ" %>
    <%= f.collection_select :cat_id, @cats, :id, :name, prompt: "猫を選んでください" %>
  </div>

  <div>
    <%= f.submit "投稿する" %>
  </div>

<% end %>
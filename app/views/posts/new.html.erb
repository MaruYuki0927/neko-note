<div class="container mt-5">

  <div class="row justify-content-center">

    <div class="col-md-8">

      <div class="card shadow-sm">

        <div class="card-body">

          <h2 class="text-center mb-4 text-dark">
            新規投稿
          </h2>

          <%= form_with model: @post, local: true do |f| %>

            <div class="mb-3">

              <%= f.label :title, "タイトル" %>

              <%= f.text_field :title,
                  class: "form-control" %>

            </div>

            <div class="mb-3">

              <%= f.label :body, "本文" %>

              <%= f.text_area :body,
                  rows: 5,
                  class: "form-control" %>

            </div>

            <div class="mb-3">

              <%= f.label :image, "画像" %>

              <%= f.file_field :image,
                  class: "form-control" %>

            </div>

            <div class="mb-3">

              <%= f.label :cat_id, "猫を選ぶ" %>

              <%= f.collection_select :cat_id,
                  @cats,
                  :id,
                  :name,
                  { prompt: "猫を選んでください" },
                  { class: "form-select" } %>

            </div>

            <div class="text-center">

              <%= f.submit "投稿する",
                  class: "btn btn-dark" %>

            </div>

          <% end %>

        </div>

      </div>

    </div>

  </div>

</div>
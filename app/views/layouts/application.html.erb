<!DOCTYPE html>
<html>
  <head>
    <title>NekoNote</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">

      <div class="container-fluid">
    
        <%= link_to "NekoNote", root_path,
            class: "navbar-brand" %>
    
        <div class="navbar-nav">
    
          <%= link_to "投稿一覧",
              posts_path,
              class: "nav-link" %>
    
          <%= link_to "猫一覧",
              cats_path,
              class: "nav-link" %>
    
          <% if user_signed_in? %>
    
            <%= link_to "投稿する",
                new_post_path,
                class: "nav-link" %>
    
            <%= link_to "猫を登録",
                new_cat_path,
                class: "nav-link" %>
    
            <%= link_to "マイページ",
                user_path(current_user),
                class: "nav-link" %>
    
            <%= link_to "ログアウト",
                destroy_user_session_path,
                data: { turbo_method: :delete },
                class: "nav-link" %>
    
          <% else %>
    
            <%= link_to "新規登録",
                new_user_registration_path,
                class: "nav-link" %>
    
            <%= link_to "ログイン",
                new_user_session_path,
                class: "nav-link" %>
    
          <% end %>
    
        </div>
    
      </div>
    
    </nav>

     <hr>

  
 <%= yield %>
  
</body>
  
</html>
